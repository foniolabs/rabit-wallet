{
  "name": "@rabit/core",
  "version": "0.1.0",
  "private": true,
  "description": "Core SDK orchestration: auth, wallet, on-ramp",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "keywords": [
    "rabit",
    "wallet",
    "connector",
    "ethereum",
    "web3",
    "core",
    "blockchain",
    "wagmi",
    "viem"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/foniolabs/rabit-wallet.git",
    "directory": "packages/core"
  },
  "dependencies": {
    "@rabit/types": "workspace:*",
    "@rabit/keys": "workspace:*",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^29.1.1",
    "tsup": "^8.0.2",
    "typescript": "^5.4.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "license": "MIT",
  "author": "Rabit contributors",
  "homepage": "https://github.com/foniolabs/rabit-wallet#readme",
  "bugs": {
    "url": "https://github.com/foniolabs/rabit-wallet/issues"
  }
}
