{
  "name": "@rabit/react",
  "version": "0.0.0",
  "description": "React SDK for Rabit - The wallet connector that actually works",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "echo 'Linting skipped - TypeScript compilation handles type checking'",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build",
    "lint:full": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@coinbase/wallet-sdk": "^4.3.0",
    "@headlessui/react": "^1.7.18",
    "@heroicons/react": "^2.1.1",
    "@rabit/connectors": "workspace:*",
    "@rabit/core": "workspace:*",
    "@rabit/smart-accounts": "workspace:*",
    "@rabit/types": "workspace:*",
    "@rabit/ui": "workspace:*",
    "@tanstack/react-query": "^5.83.0",
    "@walletconnect/utils": "^2.11.0",
    "@walletconnect/web3wallet": "^1.16.1",
    "@web3auth/account-abstraction-provider": "^9.6.0",
    "@web3auth/auth": "^10.0.5",
    "@web3auth/modal": "^10.0.5",
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.28",
    "magic-sdk": "^29.0.0",
    "permissionless": "^0.1.15",
    "react-hot-toast": "^2.5.2",
    "viem": "2.17.0",
    "wagmi": "^2.15.7",
    "zustand": "^4.5.7"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.69",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/ui": "^1.4.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^24.0.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.2",
    "vitest": "^1.4.0"
  },
  "keywords": [
    "react",
    "wallet",
    "web3",
    "ethereum",
    "wagmi",
    "viem",
    "smart-accounts",
    "account-abstraction",
    "social-auth",
    "web3-onboarding",
    "rainbowkit",
    "privy",
    "wallet-connector"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
