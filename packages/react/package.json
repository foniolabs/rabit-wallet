{
  "name": "@rabit/react",
  "version": "0.1.0",
  "private": true,
  "description": "React SDK for the Rabit embedded wallet — drop-in components & hooks",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "echo 'Linting skipped - TypeScript compilation handles type checking'",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build",
    "lint:full": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@rabit/core": "workspace:*",
    "@rabit/types": "workspace:*",
    "@rabit/evm": "workspace:*",
    "@rabit/solana": "workspace:*",
    "@rabit/onramp": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.69",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/ui": "^1.4.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^24.0.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.2",
    "vitest": "^1.4.0"
  },
  "keywords": [
    "react",
    "wallet",
    "web3",
    "ethereum",
    "wagmi",
    "viem",
    "smart-accounts",
    "account-abstraction",
    "social-auth",
    "web3-onboarding",
    "rainbowkit",
    "privy",
    "wallet-connector"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "author": "Rabit contributors",
  "homepage": "https://github.com/web3normad/rabit#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/web3normad/rabit.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/web3normad/rabit/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
