{
  "name": "rabitwallet-native",
  "version": "0.0.0",
  "private": true,
  "description": "React Native embedded wallet — the rabitwallet SDK for RN & Expo. SCAFFOLD: complete in a real RN environment before publishing.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./polyfills": "./src/polyfills.ts"
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72",
    "react-native-mmkv": ">=2",
    "react-native-get-random-values": ">=1.11",
    "buffer": ">=6"
  },
  "dependencies": {
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0",
    "@noble/secp256k1": "^2.1.0",
    "@scure/bip32": "^1.4.0",
    "@scure/bip39": "^1.3.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.91.0",
    "eventemitter3": "^5.0.1",
    "permissionless": "^0.1.45",
    "viem": "^2.8.4"
  },
  "devDependencies": {
    "@rabit/core": "workspace:*",
    "@rabit/evm": "workspace:*",
    "@rabit/keys": "workspace:*",
    "@rabit/onramp": "workspace:*",
    "@rabit/solana": "workspace:*",
    "@rabit/types": "workspace:*",
    "@types/react": "^19.2.0",
    "buffer": "^6.0.3",
    "react": "^19.2.0",
    "react-native": "^0.76.5",
    "react-native-get-random-values": "^1.11.0",
    "react-native-mmkv": "^2.12.2",
    "tsup": "^8.0.2",
    "typescript": "^7.0.2"
  }
}
