{
  "name": "@rabit/types",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript types for the Rabit embedded wallet SDK",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "rabit",
    "wallet",
    "connector",
    "ethereum",
    "web3",
    "types",
    "typescript",
    "blockchain",
    "wagmi",
    "viem"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/foniolabs/rabit-wallet.git",
    "directory": "packages/types"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^7.0.2",
    "tsup": "^8.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "license": "MIT",
  "author": "Rabit contributors",
  "homepage": "https://github.com/foniolabs/rabit-wallet#readme",
  "bugs": {
    "url": "https://github.com/foniolabs/rabit-wallet/issues"
  }
}
