{
  "name": "@rabit/smart-accounts",
  "version": "0.1.0",
  "private": true,
  "description": "ERC-4337 Account Abstraction for the Rabit ecosystem",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ethereum",
    "account-abstraction",
    "erc-4337",
    "smart-accounts",
    "web3",
    "userops",
    "bundler",
    "paymaster",
    "session-keys"
  ],
  "author": "Rabit Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rabit/packages.git",
    "directory": "packages/smart-accounts"
  },
  "dependencies": {
    "@noble/curves": "^1.3.0",
    "@noble/hashes": "^1.3.3",
    "@rabit/core": "workspace:*",
    "@rabit/types": "workspace:*",
    "@web3auth/ethereum-provider": "^9.7.0",
    "viem": "^2.8.4"
  },
  "peerDependencies": {
    "@web3auth/base": "^9.0.0",
    "@web3auth/modal": "^9.0.0",
    "magic-sdk": "^28.0.0",
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "@web3auth/modal": {
      "optional": true
    },
    "@web3auth/base": {
      "optional": true
    },
    "magic-sdk": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.19.8",
    "@types/react": "^18.2.69",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^8.56.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}