{
  "name": "rabitwallet",
  "version": "0.1.1",
  "description": "Embedded non-custodial wallet SDK with built-in fiat on/off-ramp — email/Google sign-in, split-key, EVM + Solana. One install, one import.",
  "license": "MIT",
  "author": "Rabit contributors",
  "homepage": "https://github.com/foniolabs/rabit-wallet#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/foniolabs/rabit-wallet.git",
    "directory": "packages/rabitwallet"
  },
  "bugs": {
    "url": "https://github.com/foniolabs/rabit-wallet/issues"
  },
  "keywords": [
    "wallet",
    "embedded-wallet",
    "web3",
    "ethereum",
    "solana",
    "onramp",
    "non-custodial",
    "rabit"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "rabitwallet": "./bin/rabitwallet.mjs"
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0",
    "@noble/secp256k1": "^2.1.0",
    "@scure/bip32": "^1.4.0",
    "@scure/bip39": "^1.3.0",
    "@solana/spl-token": "^0.4.15",
    "@solana/web3.js": "^1.98.4",
    "eventemitter3": "^5.0.4",
    "permissionless": "^0.3.7",
    "viem": "^2.55.2"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@rabit/core": "workspace:*",
    "@rabit/evm": "workspace:*",
    "@rabit/onramp": "workspace:*",
    "@rabit/react": "workspace:*",
    "@rabit/solana": "workspace:*",
    "@rabit/types": "workspace:*",
    "@types/react": "^18.2.69",
    "@types/react-dom": "^18.2.22",
    "tsup": "^8.0.2",
    "typescript": "^5.4.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
