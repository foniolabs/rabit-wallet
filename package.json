{
  "name": "rabit",
  "version": "1.0.0",
  "private": true,
  "description": "The wallet connector that actually works",
  "keywords": [
    "wallet",
    "web3",
    "ethereum",
    "connector",
    "rabit"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/foniolabs/rabit-wallet.git"
  },
  "license": "MIT",
  "author": "Rabit contributors",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "type-check": "turbo run type-check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r --filter='./packages/*' build && changeset publish",
    "publish:dry": "pnpm -r --filter='./packages/*' build && changeset publish --dry-run"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@turbo/gen": "^1.12.4",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^1.4.0",
    "eslint": "^8.57.0",
    "happy-dom": "^18.0.1",
    "jsdom": "^24.0.0",
    "prettier": "^3.2.5",
    "turbo": "^1.12.4",
    "typescript": "^5.4.2",
    "vitest": "^1.4.0"
  },
  "packageManager": "pnpm@8.15.4",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "overrides": {
      "viem": "2.17.11",
      "csstype": "3.2.3",
      "@types/react": "19.2.0",
      "@types/react-dom": "19.2.0",
      "zod@>=4": "4.1.12"
    }
  }
}
