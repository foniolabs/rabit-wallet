{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    
  
    "jsx": "preserve",
    "jsxImportSource": "react",
    "allowSyntheticDefaultImports": true,
    
 
    "types": ["node"],
    
 
    "baseUrl": ".",
    "paths": {
      "@rabit/core": ["../packages/core/src"],
      "@rabit/react": ["../packages/react/src"],
      "@rabit/types": ["../packages/types/src"],
      "@rabit/connectors": ["../packages/connectors/src"],
      "@rabit/smart-accounts": ["../packages/smart-accounts/src"],
      "@rabit/ui": ["../packages/ui/src"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "*.test.*",
    "*.spec.*",
    "**/*.test.*",
    "**/*.spec.*"
  ]
}