{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {

    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": false,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    
  
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    
 
    "baseUrl": ".",
    "paths": {
      "@rabit/core": ["../packages/core/src"],
      "@rabit/react": ["../packages/react/src"],
      "@rabit/types": ["../packages/types/src"],
      "@rabit/connectors": ["../packages/connectors/src"],
      "@rabit/smart-accounts": ["../packages/smart-accounts/src"],
      "@rabit/ui": ["../packages/ui/src"]
    },
    
  
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    "importHelpers": true,
    

    "incremental": true,
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    
 
    "forceConsistentCasingInFileNames": true,
    
   
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "*.test.*",
    "*.spec.*",
    "**/*.test.*",
    "**/*.spec.*"
  ]
}