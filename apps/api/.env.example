# --- Server ---
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000

# --- Auth / JWT ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# --- Dev API key (bypasses DB project lookup for local dev) ---
DEV_API_KEY=dev-api-key

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://rabit:rabit@localhost:5433/rabit?schema=public

# --- Email (Resend) ---
# Get one at https://resend.com — free tier is 100 emails/day
RESEND_API_KEY=
FROM_EMAIL=Rabit <noreply@yourdomain.com>
APP_NAME=Rabit

# --- Google OAuth ---
# From https://console.cloud.google.com/apis/credentials — OAuth 2.0 Client ID (Web)
GOOGLE_CLIENT_ID=116474648478-e92nln0osmfgpu0tcovlmootqnc9ugm5.apps.googleusercontent.com
