# Copy to .env. Expo exposes EXPO_PUBLIC_* to the app at build time.
# Defaults in App.tsx point at the live Rabit API + dev bypass, so it runs as-is.
EXPO_PUBLIC_RABIT_PROJECT_ID=dev-project
EXPO_PUBLIC_RABIT_API_KEY=dev-api-key
EXPO_PUBLIC_RABIT_API_BASE_URL=https://rabit-api-116474648478.us-central1.run.app
