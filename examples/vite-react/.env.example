# Copy to .env.local and fill in. All values are optional — the app boots without them,
# but the matching feature won't work.

# --- Rabit project credentials ---
# From the dashboard (or apps/api/scripts/mint-keys.ts). Falls back to the dev
# bypass (dev-project / dev-api-key) if unset.
VITE_RABIT_PROJECT_ID=
VITE_RABIT_API_KEY=
VITE_RABIT_API_BASE_URL=http://localhost:3001

# --- Google Sign-In ---
# Same value as apps/api/.env GOOGLE_CLIENT_ID (the API verifies tokens issued for this client).
VITE_GOOGLE_CLIENT_ID=

# --- Smart Accounts (ERC-4337 bundler) ---
# Sign up at https://dashboard.pimlico.io (or ZeroDev / Alchemy / Stackup).
# Example: https://api.pimlico.io/v2/sepolia/rpc?apikey=pim_xxx
VITE_BUNDLER_URL=
# Optional — for gas sponsorship (same provider). Leave empty if you want users to pay gas.
VITE_PAYMASTER_URL=
# kernel | safe | light
VITE_SMART_ACCOUNT_TYPE=kernel
