# Copy to .env.gcp (which is gitignored) and edit:
#   cp scripts/gcp/.env.example scripts/gcp/.env.gcp
#   $EDITOR scripts/gcp/.env.gcp
# Then run:
#   set -a && source scripts/gcp/.env.gcp && set +a
#   bash scripts/gcp/00-bootstrap.sh

GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

DB_INSTANCE_NAME=rabit-db
DB_PASSWORD=replace-with-strong-password-min-16-chars

# Filled in automatically after 00-bootstrap.sh prints it. Format:
# project-id:region:instance-name
DB_INSTANCE_CONNECTION=

# Optional — get from https://resend.com (or leave blank for placeholder).
RESEND_API_KEY=
